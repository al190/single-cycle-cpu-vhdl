library IEEE;
use IEEE.std_logic_1164.ALL;
use IEEE.numeric_std.ALL;
use work.isa_riscv.ALL;

entity alu is


	generic( bits : integer := 32 );
	port ( 
	   a: in std_logic_vector(bits-1 downto 0);
	   b: in std_logic_vector(bits-1 downto 0);
	   op: in std_logic_vector(3 downto 0);
	   c: out std_logic_vector(bits-1 downto 0);
	   f_zero: out std_logic;
	   f_ltzero: out std_logic
	   );
	-------------------------------

end entity alu;

architecture Behavioral of alu is

begin

    process(a, b, op)
        variable result : std_logic_vector(bits-1 downto 0);
        variable shift_amount : natural range 0 to bits - 1;
    begin
        result := (others => '0');
        shift_amount := to_integer(unsigned(b) mod to_unsigned(bits, bits));

        case op is
            when opcode_ADD =>
                result := std_logic_vector(unsigned(a) + unsigned(b));
            when opcode_SUB =>
                result := std_logic_vector(unsigned(a) - unsigned(b));
            when opcode_SLL =>
                result := std_logic_vector(shift_left(unsigned(a), shift_amount));
            when opcode_SLT =>
                if signed(a) < signed(b) then
                    result(0) := '1';
                end if;
            when opcode_SLTU =>
                if unsigned(a) < unsigned(b) then
                    result(0) := '1';
                end if;
            when opcode_XOR =>
                result := a xor b;
            when opcode_SRL =>
                result := std_logic_vector(shift_right(unsigned(a), shift_amount));
            when opcode_SRA =>
                result := std_logic_vector(shift_right(signed(a), shift_amount));
            when opcode_OR =>
                result := a or b;
            when opcode_AND =>
                result := a and b;
            when others =>
                result := (others => '0');
        end case;

        c <= result;
        if result = (result'range => '0') then
            f_zero <= '1';
        else
            f_zero <= '0';
        end if;
        f_ltzero <= result(bits - 1);
    end process;

end Behavioral;
